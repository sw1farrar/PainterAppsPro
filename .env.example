# Supabase Postgres (reuse existing PainterApps project)
# App runtime: pooled URL (IPv4 / Vercel-friendly), port 6543
DATABASE_URL="postgresql://USER.PROJECT_REF:PASSWORD@aws-1-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Migrations: direct DB host, port 5432
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# xAI Grok — AI product attribute lookup (Settings / Product Library)
XAI_API_KEY=""
# Optional override (default: grok-4.5)
# XAI_MODEL="grok-4.5"
