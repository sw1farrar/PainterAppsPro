# =============================================================================
# PainterApps Pro — .gitignore
# Next.js / TypeScript / Prisma — keep the repo lean; keep Dropbox junk out.
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# -----------------------------------------------------------------------------
# Dropbox conflict leftovers (never commit / never typecheck)
# Matches "Selective Sync Conflict", "Conflicted Copy", and numbered variants
# -----------------------------------------------------------------------------
* (Selective Sync Conflict*)/
* (Conflicted Copy)*
*.dropbox
.dropbox/
.dropbox.attr
.dropbox.cache

# -----------------------------------------------------------------------------
# Next.js / React / build output
# -----------------------------------------------------------------------------
.next/
out/
dist/
build/
.turbo/
.swc/

# -----------------------------------------------------------------------------
# Caches
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Vercel / deploy
# -----------------------------------------------------------------------------
.vercel/
.netlify/

# -----------------------------------------------------------------------------
# Environment & secrets (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Logs & debug
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Testing / coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/
.vitest/

# -----------------------------------------------------------------------------
# TypeScript (auto-generated by Next.js)
# -----------------------------------------------------------------------------
next-env.d.ts

# -----------------------------------------------------------------------------
# Prisma
# Commit prisma/migrations/ — required for deploy & teammate sync.
# Ignore local SQLite DBs and generated client output only.
# -----------------------------------------------------------------------------
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal
src/generated/

# -----------------------------------------------------------------------------
# Local file uploads (keep folder via .gitkeep)
# -----------------------------------------------------------------------------
public/uploads/*
!public/uploads/.gitkeep
uploads/
!uploads/.gitkeep

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
*.local
.temp/
.tmp/
tmp/
